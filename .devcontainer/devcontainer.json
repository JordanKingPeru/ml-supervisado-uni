{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "02_Contenido/M04_XAI_Produccion/app/app_basic.py"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "updateContentCommand": "pip3 install --user -r 02_Contenido/M00_Onboarding/requirements.txt; pip3 install --user jupyter; echo '✅ Packages installed and Requirements met'",
  "postAttachCommand": {
    "server": "streamlit run 02_Contenido/M04_XAI_Produccion/app/app_basic.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {
      "label": "Application",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8501
  ]
}
